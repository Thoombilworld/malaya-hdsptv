<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/login/?$ admin/login.php [L]
RewriteRule ^admin/logout/?$ admin/logout.php [L]
RewriteRule ^admin/(users|ads|seo|social|social_dispatch|homepage|logs)/?$ admin/$1.php [L]
RewriteRule ^admin/content/?$ admin/content/index.php [L]
RewriteRule ^admin/content/(articles|article_add|article_edit|article_delete|categories|tags)/?$ admin/content/$1.php [QSA,L]

RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^post/([^/]+)/?$ post.php?slug=$1 [QSA,L]
RewriteRule ^category/([^/]+)/?$ category.php?slug=$1 [QSA,L]
RewriteRule ^tag/([^/]+)/?$ tag.php?slug=$1 [QSA,L]
RewriteRule ^search/?$ search.php [QSA,L]
RewriteRule ^search/(.+)/?$ search.php?q=$1 [QSA,L]
RewriteRule ^about/?$ about.php [L]
RewriteRule ^contact/?$ contact.php [L]
RewriteRule ^breaking/?$ breaking.php [L]
RewriteRule ^trending/?$ trending.php [L]
RewriteRule ^video/?$ video.php [L]
RewriteRule ^gallery/?$ gallery.php [L]
RewriteRule ^live/?$ live.php [L]
RewriteRule ^profile/?$ profile.php [L]
RewriteRule ^saved/?$ saved.php [L]
RewriteRule ^notifications/?$ notifications.php [L]
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType image/svg+xml "access plus 6 months"
ExpiresByType image/png "access plus 6 months"
ExpiresByType image/jpeg "access plus 6 months"
ExpiresByType image/webp "access plus 6 months"
ExpiresByType application/font-woff2 "access plus 6 months"
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/plain text/html text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

Options -Indexes
